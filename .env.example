# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate a key pair with:  npx web-push generate-vapid-keys
#
# Server-side only (Vercel project environment variables — NEVER committed,
# NEVER shipped to the client):
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Client-side (safe to expose — this is the PUBLIC key only). Must match
# VAPID_PUBLIC_KEY. Exposed to the app at build time via Vite:
VITE_VAPID_PUBLIC_KEY=

# ─── Scheduled sender security ───────────────────────────────────────────────
# Secret that protects /api/cron/dispatch. Vercel Cron automatically sends
# "Authorization: Bearer $CRON_SECRET"; an external cron may pass "?key=...".
# Generate any long random string, e.g.:  openssl rand -hex 32
CRON_SECRET=

# ─── Persistent subscription store (Vercel KV or Upstash Redis) ──────────────
# Attach a Vercel KV store (Storage tab) and it injects KV_REST_API_URL and
# KV_REST_API_TOKEN automatically. If you use Upstash directly, set the
# UPSTASH_* pair instead — the app reads either.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
