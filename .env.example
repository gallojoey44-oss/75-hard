# Web Push (VAPID) credentials — required for server-side scheduled reminders.
# Generate a pair with:  npx web-push generate-vapid-keys
#
# Server-side only (Vercel project environment variables — NEVER committed,
# NEVER shipped to the client):
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Client-side (safe to expose — this is the PUBLIC key only). Must match
# VAPID_PUBLIC_KEY. Exposed to the app at build time via Vite:
VITE_VAPID_PUBLIC_KEY=
